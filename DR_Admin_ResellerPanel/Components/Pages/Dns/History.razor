@page "/dns/history"

<div id="dns-history-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-clock-history"></i> DNS Change History</h2>
            <p class="text-muted mb-0">Review DNS changes across all domains.</p>
        </div>
    </div>

    <div id="dns-history-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="dns-history-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label mb-1" for="dns-history-filter-domain-name">Domain name</label>
                    <input class="form-control" id="dns-history-filter-domain-name" type="text" placeholder="example.com" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label mb-1" for="dns-history-filter-occurred-from">Occurred from</label>
                    <input class="form-control" id="dns-history-filter-occurred-from" type="datetime-local" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label mb-1" for="dns-history-filter-occurred-to">Occurred to</label>
                    <input class="form-control" id="dns-history-filter-occurred-to" type="datetime-local" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="dns-history-page-size">Page size</label>
                    <select class="form-select" id="dns-history-page-size">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-primary" id="dns-history-apply" type="button"><i class="bi bi-funnel"></i> Apply</button>
                    <button class="btn btn-outline-secondary" id="dns-history-reset" type="button"><i class="bi bi-x-circle"></i> Reset</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Occurred</th>
                            <th>Domain</th>
                            <th>Action</th>
                            <th>Details</th>
                            <th>Source</th>
                            <th>User</th>
                        </tr>
                    </thead>
                    <tbody id="dns-history-table-body">
                        <tr>
                            <td colspan="6" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="text-muted small" id="dns-history-pagination-info"></div>
                <div id="dns-history-paging-controls" class="mt-3">
                    <nav aria-label="DNS history pagination">
                        <ul class="pagination justify-content-center mb-0" id="dns-history-paging-controls-list"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

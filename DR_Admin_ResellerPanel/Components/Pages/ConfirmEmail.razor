@page "/my-account/confirm-email"
@layout EmptyLayout

<PageTitle>Confirm Email - DR Admin</PageTitle>

<div class="login-page">
    <div class="container">
        <div class="row align-items-center justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="card shadow login-card">
                    <div class="card-body p-4">

                        <div class="text-center mb-4">
                            <div class="login-brand-icon">
                                <i class="bi bi-envelope-check-fill"></i>
                            </div>
                            <h4 class="mt-2 mb-0">Confirm Email</h4>
                            <p class="text-muted small mb-0" id="confirm-email-status">
                                Confirm email for <strong id="confirm-email-address">your account</strong>.
                            </p>
                        </div>

                        <div id="confirm-email-alert-success" class="alert alert-success d-none" role="alert"></div>
                        <div id="confirm-email-alert-error" class="alert alert-danger d-none" role="alert"></div>

                        <div id="confirm-email-form">
                            <button type="button" class="btn btn-primary w-100" id="confirm-email-submit">
                                <i class="bi bi-check-lg"></i> Confirm Email
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <a href="login" class="text-decoration-none small">
                                <i class="bi bi-arrow-left"></i> Back to Sign In
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@page "/initialize"
@layout EmptyLayout

<PageTitle>Initialize Database - DR Admin Reseller Panel</PageTitle>

<div id="initialization-page" class="login-page">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-sm-11 col-md-9 col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-1"><i class="bi bi-database-fill-gear"></i> Initial System Setup</h4>
                        <p class="mb-0 small opacity-75">Create the first administrator account and seed core data.</p>
                    </div>
                    <div class="card-body p-4">
                        <div id="initialization-alert-info" class="alert alert-info" role="alert">
                            <div class="fw-semibold mb-1">Why this step is required</div>
                            <div>This is a first-time setup process. The system needs an initial administrator user and baseline code-table data before normal login can be used.</div>
                        </div>

                        <div id="initialization-alert-success" class="alert alert-success d-none" role="alert"></div>
                        <div id="initialization-alert-error" class="alert alert-danger d-none" role="alert"></div>

                        <div id="initialization-debug-import" class="card border-warning mb-3 d-none">
                            <div class="card-header bg-warning-subtle">
                                <h6 class="mb-0"><i class="bi bi-bug"></i> Debug Import</h6>
                            </div>
                            <div class="card-body">
                                <p class="small text-muted mb-2">Import admin user and MyCompany from a snapshot file located in the API <code>DebugSnapshots</code> directory.</p>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-8">
                                        <label for="initialization-debug-import-file" class="form-label">Snapshot file name</label>
                                        <input id="initialization-debug-import-file" class="form-control" type="text" placeholder="admin-mycompany-debug.json" />
                                    </div>
                                    <div class="col-md-4">
                                        <button id="initialization-debug-import-button" type="button" class="btn btn-outline-warning w-100">
                                            <i class="bi bi-upload"></i> Import Snapshot
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <form id="initialization-form" novalidate>
                            <div class="mb-3">
                                <label for="initialization-username" class="form-label">Username</label>
                                <input id="initialization-username" class="form-control" type="text" value="admin" autocomplete="username" required />
                                <div class="form-text">Default username is <code>admin</code>.</div>
                            </div>

                            <div class="mb-3">
                                <label for="initialization-email" class="form-label">Email</label>
                                <input id="initialization-email" class="form-control" type="email" placeholder="admin@example.com" autocomplete="email" required />
                            </div>

                            <hr class="my-4" />
                            <h6 class="mb-3"><i class="bi bi-building"></i> My Company (basic)</h6>

                            <div class="mb-3">
                                <label for="initialization-company-name" class="form-label">Company Name</label>
                                <input id="initialization-company-name" class="form-control" type="text" placeholder="My Company Ltd" autocomplete="organization" />
                            </div>

                            <div class="mb-3">
                                <label for="initialization-company-email" class="form-label">Company Email</label>
                                <input id="initialization-company-email" class="form-control" type="email" placeholder="info@company.com" autocomplete="email" />
                            </div>

                            <div class="mb-3">
                                <label for="initialization-company-phone" class="form-label">Company Phone</label>
                                <input id="initialization-company-phone" class="form-control" type="text" placeholder="+47 123 45 678" autocomplete="tel" />
                            </div>

                            <div class="mb-3">
                                <label for="initialization-password" class="form-label">Password</label>
                                <div class="input-group">
                                    <input id="initialization-password" class="form-control" type="password" autocomplete="new-password" required />
                                    <button id="initialization-toggle-password" class="btn btn-outline-secondary" type="button" data-target="initialization-password" aria-label="Show or hide password">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <div class="form-text">Minimum 8 characters and include uppercase, lowercase, number and special character.</div>
                            </div>

                            <div class="mb-3">
                                <label for="initialization-password-confirm" class="form-label">Confirm Password</label>
                                <div class="input-group">
                                    <input id="initialization-password-confirm" class="form-control" type="password" autocomplete="new-password" required />
                                    <button id="initialization-toggle-password-confirm" class="btn btn-outline-secondary" type="button" data-target="initialization-password-confirm" aria-label="Show or hide confirmation password">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3 d-none" id="initialization-seed-test-data-wrapper">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="true" id="initialization-seed-test-data" />
                                    <label class="form-check-label" for="initialization-seed-test-data">
                                        Seed extended test data after initialization (calls <code>/api/v1/Test/seed-data</code>)
                                    </label>
                                </div>
                            </div>

                            <button id="initialization-submit" type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-play-circle"></i> Initialize Database
                            </button>
                        </form>

                        <div id="initialization-result" class="mt-4 d-none">
                            <h5 class="mb-2"><i class="bi bi-check2-circle"></i> Setup Result</h5>
                            <div id="initialization-done-summary" class="small text-muted mb-2"></div>
                        </div>

                        <div id="initialization-seed-data-section" class="card shadow-sm mt-4 d-none">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center gap-2">
                                <h5 class="mb-0"><i class="bi bi-database-add"></i> Seed Test Data</h5>
                                <button id="initialization-seed-data-button" type="button" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-database-add"></i> Seed Test Data
                                </button>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-0">You can now seed extended test data.</p>
                            </div>
                        </div>

                        <div class="mt-4 d-none" id="initialization-login-section">
                            <a href="/login" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-box-arrow-in-right"></i> Return to Login
                            </a>
                        </div>

                        <div id="initialization-proceed-info" class="mt-3 small text-muted d-none">
                            Next step: sign in using your new administrator account and continue normal configuration.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@page "/infrastructure/server-control-panels"

<div id="server-control-panels-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-window-stack"></i> Server Control Panel Instances</h2>
            <p class="text-muted mb-0">Define control panel installations and connect them to servers and panel types.</p>
        </div>
        <button class="btn btn-primary" id="server-control-panels-create" type="button">
            <i class="bi bi-plus-circle"></i> New instance
        </button>
    </div>

    <div id="server-control-panels-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="server-control-panels-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label mb-1" for="server-control-panels-filter-server">Server</label>
                    <select class="form-select" id="server-control-panels-filter-server">
                        <option value="">All servers</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label mb-1" for="server-control-panels-filter-type">Panel type</label>
                    <select class="form-select" id="server-control-panels-filter-type">
                        <option value="">All panel types</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label mb-1" for="server-control-panels-filter-health">Health</label>
                    <select class="form-select" id="server-control-panels-filter-health">
                        <option value="all">All</option>
                        <option value="healthy">Healthy</option>
                        <option value="error">Error</option>
                        <option value="unknown">Unknown</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Control Panel Instances</h5>
            <span class="badge bg-primary" id="server-control-panels-count">0</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Server</th>
                            <th>Panel Type</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                            <th>Health</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="server-control-panels-table-body">
                        <tr><td colspan="6" class="text-center"><div class="spinner-border text-primary"></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="server-control-panels-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="server-control-panels-modal-title">New Control Panel Instance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="server-control-panels-form" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="server-control-panels-server-id">Server <span class="text-danger">*</span></label>
                            <select class="form-select" id="server-control-panels-server-id">
                                <option value="">Select server...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="server-control-panels-type-id">Panel Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="server-control-panels-type-id">
                                <option value="">Select panel type...</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label" for="server-control-panels-api-url">API URL <span class="text-danger">*</span></label>
                            <input class="form-control" id="server-control-panels-api-url" type="text" placeholder="https://panel.example.com" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="server-control-panels-port">Port</label>
                            <input class="form-control" id="server-control-panels-port" type="number" min="1" max="65535" value="2087" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="server-control-panels-use-https" checked />
                                <label class="form-check-label" for="server-control-panels-use-https">HTTPS</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="server-control-panels-ip-id">Bound IP (optional)</label>
                            <select class="form-select" id="server-control-panels-ip-id">
                                <option value="">No IP binding</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="server-control-panels-status">Status</label>
                            <select class="form-select" id="server-control-panels-status">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Error">Error</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="server-control-panels-username">Username</label>
                            <input class="form-control" id="server-control-panels-username" type="text" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="server-control-panels-api-token">API Token</label>
                            <input class="form-control" id="server-control-panels-api-token" type="text" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="server-control-panels-api-key">API Key</label>
                            <input class="form-control" id="server-control-panels-api-key" type="text" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="server-control-panels-password">Password</label>
                            <input class="form-control" id="server-control-panels-password" type="password" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="server-control-panels-notes">Notes</label>
                            <textarea class="form-control" id="server-control-panels-notes" rows="2"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="server-control-panels-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="server-control-panels-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Control Panel Instance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete instance <strong id="server-control-panels-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="server-control-panels-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

@page "/infrastructure/servers"

<div id="servers-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-server"></i> Servers</h2>
            <p class="text-muted mb-0">Manage physical and virtual servers in your infrastructure</p>
        </div>
        <button class="btn btn-primary" id="servers-create" type="button">
            <i class="bi bi-plus-circle"></i> New Server
        </button>
    </div>

    <div id="servers-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="servers-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-server"></i> Servers</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Location</th>
                            <th>Server Type</th>
                            <th>OS</th>
                            <th>Provider</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="servers-table-body">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="servers-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="servers-modal-title">New Server</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="servers-form" novalidate>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="servers-name" class="form-label">Server Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="servers-name" placeholder="e.g. web-prod-01">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="servers-location" class="form-label">Location</label>
                            <input type="text" class="form-control" id="servers-location" placeholder="e.g. Amsterdam, NL">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="servers-server-type-id" class="form-label">Server Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="servers-server-type-id">
                                <option value="">Select Server Type...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="servers-operating-system-id" class="form-label">Operating System <span class="text-danger">*</span></label>
                            <select class="form-select" id="servers-operating-system-id">
                                <option value="">Select OS...</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="servers-host-provider-id" class="form-label">Hosting Provider</label>
                            <select class="form-select" id="servers-host-provider-id">
                                <option value="">Select Provider...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="servers-status" class="form-label">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="servers-status" checked>
                                <label class="form-check-label" for="servers-status">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="servers-cpu-cores" class="form-label">CPU Cores</label>
                            <input type="number" class="form-control" id="servers-cpu-cores" min="1">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="servers-ram-mb" class="form-label">RAM (MB)</label>
                            <input type="number" class="form-control" id="servers-ram-mb" min="1">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="servers-disk-space-gb" class="form-label">Disk Space (GB)</label>
                            <input type="number" class="form-control" id="servers-disk-space-gb" min="1">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="servers-notes" class="form-label">Notes</label>
                        <textarea class="form-control" id="servers-notes" rows="2"></textarea>
                    </div>

                    <div class="card border">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-window-stack"></i> Control Panel Instances</h6>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="servers-panels-manage-all">
                                    <i class="bi bi-box-arrow-up-right"></i> Full manager
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="servers-panels-add" disabled>
                                    <i class="bi bi-plus-lg"></i> Add panel
                                </button>
                            </div>
                        </div>
                        <div class="card-body">
                            <div id="servers-panels-new-server-hint" class="small text-muted">
                                Save server first to add panel instances directly.
                            </div>
                            <div id="servers-panels-list-wrapper" class="d-none">
                                <ul class="list-group" id="servers-panels-list">
                                    <li class="list-group-item text-muted">No control panel instances configured.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="servers-save">
                    <i class="bi bi-check-lg"></i> Save
                </button>
            </div>
        </div>
    </div>

<div class="modal fade" id="servers-panel-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="servers-panel-modal-title">Add Control Panel Instance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="servers-panel-form" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="servers-panel-control-panel-type-id">Panel Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="servers-panel-control-panel-type-id">
                                <option value="">Select Panel Type...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="servers-panel-ip-address-id">Bound IP (optional)</label>
                            <select class="form-select" id="servers-panel-ip-address-id">
                                <option value="">No IP binding</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label" for="servers-panel-api-url">API URL <span class="text-danger">*</span></label>
                            <input class="form-control" id="servers-panel-api-url" type="text" placeholder="https://panel.example.com" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="servers-panel-port">Port</label>
                            <input class="form-control" id="servers-panel-port" type="number" min="1" max="65535" value="2087" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="servers-panel-use-https" checked />
                                <label class="form-check-label" for="servers-panel-use-https">HTTPS</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="servers-panel-username">Username</label>
                            <input class="form-control" id="servers-panel-username" type="text" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="servers-panel-api-token">API Token</label>
                            <input class="form-control" id="servers-panel-api-token" type="text" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="servers-panel-api-key">API Key</label>
                            <input class="form-control" id="servers-panel-api-key" type="text" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="servers-panel-password">Password</label>
                            <input class="form-control" id="servers-panel-password" type="password" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="servers-panel-status">Status</label>
                            <select class="form-select" id="servers-panel-status">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Error">Error</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="servers-panel-notes">Notes</label>
                            <textarea class="form-control" id="servers-panel-notes" rows="2"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="servers-panel-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>
</div>

<div class="modal fade" id="servers-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete server <strong id="servers-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone. IP addresses and other resources must be reassigned first.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="servers-confirm-delete">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>
<script src="/js/servers.js"></script>

@page "/billing/order-tax-snapshots"

<div id="order-tax-snapshots-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-receipt"></i> Order Tax Snapshots</h2>
            <p class="text-muted mb-0">Read-only finalized tax snapshots with idempotency and FX provenance.</p>
        </div>
        <button class="btn btn-primary" id="order-tax-snapshots-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    </div>

    <div id="order-tax-snapshots-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="order-tax-snapshots-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Snapshot ID</th>
                            <th>Order ID</th>
                            <th>Idempotency Key</th>
                            <th>Net</th>
                            <th>Tax</th>
                            <th>Gross</th>
                            <th>Captured</th>
                        </tr>
                    </thead>
                    <tbody id="order-tax-snapshots-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@page "/billing/tax-evidence"

<div id="tax-evidence-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-shield-check"></i> Tax Determination Evidence</h2>
            <p class="text-muted mb-0">Compliance evidence used in tax determination, including location and VAT validation data.</p>
        </div>
        <button class="btn btn-primary" id="tax-evidence-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    </div>

    <div id="tax-evidence-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-evidence-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Evidence ID</th>
                            <th>Billing Country</th>
                            <th>State</th>
                            <th>IP Address</th>
                            <th>Tax ID</th>
                            <th>Provider</th>
                            <th>Captured</th>
                        </tr>
                    </thead>
                    <tbody id="tax-evidence-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

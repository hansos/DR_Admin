@page "/billing/tax-categories"

<div id="tax-categories-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-tags"></i> Tax Categories</h2>
            <p class="text-muted mb-0">Manage country/state scoped tax category codes like STANDARD and REDUCED.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="tax-categories-create" type="button"><i class="bi bi-plus-circle"></i> New</button>
            <button class="btn btn-outline-primary" id="tax-categories-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
    </div>

    <div id="tax-categories-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-categories-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Country</th>
                            <th>State</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tax-categories-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-categories-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tax-categories-modal-title">New Tax Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tax-categories-form" novalidate>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="tax-categories-country" class="form-label">Country <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-categories-country" maxlength="2" />
                        </div>
                        <div class="col-6">
                            <label for="tax-categories-state" class="form-label">State</label>
                            <input type="text" class="form-control" id="tax-categories-state" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-6">
                            <label for="tax-categories-code" class="form-label">Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-categories-code" />
                        </div>
                        <div class="col-6">
                            <label for="tax-categories-name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-categories-name" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="tax-categories-description" class="form-label">Description</label>
                        <textarea class="form-control" id="tax-categories-description" rows="2"></textarea>
                    </div>
                    <div class="mt-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="tax-categories-is-active" checked />
                            <label class="form-check-label" for="tax-categories-is-active">Active</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="tax-categories-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-categories-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete tax category <strong id="tax-categories-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="tax-categories-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

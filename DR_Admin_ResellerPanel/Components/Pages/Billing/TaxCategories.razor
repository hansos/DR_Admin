@page "/billing/tax-categories"

<div id="tax-categories-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-tags"></i> Tax Categories</h2>
            <p class="text-muted mb-0">Manage country/state scoped tax category codes like STANDARD and REDUCED.</p>
        </div>
        <button class="btn btn-primary" id="tax-categories-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    </div>

    <div id="tax-categories-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-categories-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Country</th>
                            <th>State</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="tax-categories-table-body">
                        <tr>
                            <td colspan="6" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@page "/billing/tax-jurisdictions"

<div id="tax-jurisdictions-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-geo-alt"></i> Tax Jurisdictions</h2>
            <p class="text-muted mb-0">Manage VAT/TAX jurisdictions used by tax rules and registrations.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="tax-jurisdictions-create" type="button"><i class="bi bi-plus-circle"></i> New</button>
            <button class="btn btn-outline-primary" id="tax-jurisdictions-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
    </div>

    <div id="tax-jurisdictions-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-jurisdictions-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Country</th>
                            <th>State</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tax-jurisdictions-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-jurisdictions-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tax-jurisdictions-modal-title">New Tax Jurisdiction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tax-jurisdictions-form" novalidate>
                    <div class="mb-3">
                        <label for="tax-jurisdictions-code" class="form-label">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tax-jurisdictions-code" placeholder="e.g. NO-NATIONAL" />
                    </div>
                    <div class="mb-3">
                        <label for="tax-jurisdictions-name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tax-jurisdictions-name" placeholder="e.g. Norway VAT" />
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="tax-jurisdictions-country" class="form-label">Country <span class="text-danger">*</span></label>
                            <select class="form-select" id="tax-jurisdictions-country">
                                <option value="">Select country</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label for="tax-jurisdictions-state" class="form-label">State</label>
                            <input type="text" class="form-control" id="tax-jurisdictions-state" placeholder="Optional" />
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="tax-jurisdictions-authority" class="form-label">Tax authority <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tax-jurisdictions-authority" />
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-6">
                            <label for="tax-jurisdictions-currency" class="form-label">Tax currency <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-jurisdictions-currency" maxlength="3" placeholder="EUR" />
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="tax-jurisdictions-is-active" checked>
                                <label class="form-check-label" for="tax-jurisdictions-is-active">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="tax-jurisdictions-notes" class="form-label">Notes</label>
                        <textarea class="form-control" id="tax-jurisdictions-notes" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="tax-jurisdictions-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-jurisdictions-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete tax jurisdiction <strong id="tax-jurisdictions-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="tax-jurisdictions-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

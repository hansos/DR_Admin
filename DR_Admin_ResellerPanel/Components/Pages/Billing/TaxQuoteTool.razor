@page "/billing/tax-quote"

<div id="tax-quote-tool-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-calculator"></i> Tax Quote Tool</h2>
            <p class="text-muted mb-0">Prepare quote inputs and preview line-level tax output from the tax calculation API.</p>
        </div>
        <button class="btn btn-primary" id="tax-quote-tool-run" type="button"><i class="bi bi-play-circle"></i> Run Quote</button>
    </div>

    <div id="tax-quote-tool-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-quote-tool-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <h5 class="mb-0">Quote Input</h5>
        </div>
        <div class="card-body">
            <p class="text-muted mb-0">Use this page to assemble quote request payloads and inspect calculation output.</p>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Quote Result</h5>
        </div>
        <div class="card-body">
            <pre id="tax-quote-tool-result" class="mb-0">No quote executed.</pre>
        </div>
    </div>
</div>

@page "/billing/payment-gateways"

<div id="payment-gateways-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-credit-card-2-front"></i> Payment Gateways</h2>
            <p class="text-muted mb-0">Manage payment gateways and map them to payment instruments.</p>
        </div>
        <button class="btn btn-primary" id="payment-gateways-create" type="button">
            <i class="bi bi-plus-circle"></i> New Payment Gateway
        </button>
    </div>

    <div id="payment-gateways-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="payment-gateways-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Gateways</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Provider</th>
                            <th>Instrument</th>
                            <th>Status</th>
                            <th>Sort</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="payment-gateways-table-body">
                        <tr>
                            <td colspan="7" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="payment-gateways-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="payment-gateways-modal-title">New Payment Gateway</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="payment-gateways-form" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="payment-gateways-name" class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="payment-gateways-name" placeholder="e.g. Stripe Card Gateway">
                        </div>
                        <div class="col-md-6">
                            <label for="payment-gateways-provider-code" class="form-label">Provider code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="payment-gateways-provider-code" placeholder="e.g. stripe">
                        </div>
                        <div class="col-md-6">
                            <label for="payment-gateways-instrument" class="form-label">Payment instrument <span class="text-danger">*</span></label>
                            <select class="form-select" id="payment-gateways-instrument"></select>
                        </div>
                        <div class="col-md-3">
                            <label for="payment-gateways-sort-order" class="form-label">Sort order</label>
                            <input type="number" min="0" class="form-control" id="payment-gateways-sort-order" placeholder="10">
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="payment-gateways-is-active" checked>
                                    <label class="form-check-label" for="payment-gateways-is-active">Active</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="payment-gateways-is-default">
                                    <label class="form-check-label" for="payment-gateways-is-default">Default for instrument</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label for="payment-gateways-api-key" class="form-label">API key</label>
                        <input type="text" class="form-control" id="payment-gateways-api-key" placeholder="Enter API key (leave empty on edit to keep existing)">
                    </div>
                    <div class="mt-3">
                        <label for="payment-gateways-api-secret" class="form-label">API secret</label>
                        <input type="password" class="form-control" id="payment-gateways-api-secret" placeholder="Enter API secret (leave empty on edit to keep existing)">
                    </div>
                    <div class="mt-3">
                        <label for="payment-gateways-webhook-url" class="form-label">Webhook URL</label>
                        <input type="text" class="form-control" id="payment-gateways-webhook-url" placeholder="https://...">
                    </div>
                    <div class="mt-3">
                        <label for="payment-gateways-description" class="form-label">Description</label>
                        <textarea class="form-control" id="payment-gateways-description" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="payment-gateways-save">
                    <i class="bi bi-check-lg"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="payment-gateways-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete payment gateway <strong id="payment-gateways-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="payment-gateways-confirm-delete">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

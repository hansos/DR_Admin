@page "/billing/tax-rules"

<div id="tax-rules-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-diagram-3"></i> Tax Rules</h2>
            <p class="text-muted mb-0">Manage effective tax rules, scope, priority and category mapping.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="tax-rules-create" type="button"><i class="bi bi-plus-circle"></i> New</button>
            <button class="btn btn-outline-primary" id="tax-rules-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
    </div>

    <div id="tax-rules-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-rules-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Country</th>
                            <th>State</th>
                            <th>Category</th>
                            <th>Rate</th>
                            <th>Effective Range</th>
                            <th>Priority</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tax-rules-table-body">
                        <tr>
                            <td colspan="8" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-rules-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tax-rules-modal-title">New Tax Rule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tax-rules-form" novalidate>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label for="tax-rules-country" class="form-label">Country <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-rules-country" maxlength="2" />
                        </div>
                        <div class="col-md-3">
                            <label for="tax-rules-state" class="form-label">State</label>
                            <input type="text" class="form-control" id="tax-rules-state" />
                        </div>
                        <div class="col-md-3">
                            <label for="tax-rules-category-id" class="form-label">Tax Category Id</label>
                            <input type="number" class="form-control" id="tax-rules-category-id" min="1" />
                        </div>
                        <div class="col-md-3">
                            <label for="tax-rules-category" class="form-label">Category <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-rules-category" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label for="tax-rules-name" class="form-label">Tax name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-rules-name" />
                        </div>
                        <div class="col-md-4">
                            <label for="tax-rules-rate" class="form-label">Tax rate <span class="text-danger">*</span></label>
                            <input type="number" step="0.000001" min="0" class="form-control" id="tax-rules-rate" />
                        </div>
                        <div class="col-md-4">
                            <label for="tax-rules-priority" class="form-label">Priority</label>
                            <input type="number" class="form-control" id="tax-rules-priority" value="0" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label for="tax-rules-effective-from" class="form-label">Effective from <span class="text-danger">*</span></label>
                            <input type="datetime-local" class="form-control" id="tax-rules-effective-from" />
                        </div>
                        <div class="col-md-6">
                            <label for="tax-rules-effective-until" class="form-label">Effective until</label>
                            <input type="datetime-local" class="form-control" id="tax-rules-effective-until" />
                        </div>
                    </div>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label for="tax-rules-authority" class="form-label">Tax authority <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="tax-rules-authority" />
                        </div>
                        <div class="col-md-6">
                            <label for="tax-rules-registration-number" class="form-label">Registration number</label>
                            <input type="text" class="form-control" id="tax-rules-registration-number" />
                        </div>
                    </div>
                    <div class="row g-3 mt-2">
                        <div class="col-md-3 form-check">
                            <input class="form-check-input" type="checkbox" id="tax-rules-is-active" checked />
                            <label class="form-check-label" for="tax-rules-is-active">Active</label>
                        </div>
                        <div class="col-md-3 form-check">
                            <input class="form-check-input" type="checkbox" id="tax-rules-applies-setup" checked />
                            <label class="form-check-label" for="tax-rules-applies-setup">Applies setup</label>
                        </div>
                        <div class="col-md-3 form-check">
                            <input class="form-check-input" type="checkbox" id="tax-rules-applies-recurring" checked />
                            <label class="form-check-label" for="tax-rules-applies-recurring">Applies recurring</label>
                        </div>
                        <div class="col-md-3 form-check">
                            <input class="form-check-input" type="checkbox" id="tax-rules-reverse-charge" />
                            <label class="form-check-label" for="tax-rules-reverse-charge">Reverse charge</label>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="tax-rules-notes" class="form-label">Internal notes</label>
                        <textarea class="form-control" id="tax-rules-notes" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="tax-rules-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-rules-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete tax rule <strong id="tax-rules-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="tax-rules-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

@page "/billing/tax-rules"

<div id="tax-rules-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-diagram-3"></i> Tax Rules</h2>
            <p class="text-muted mb-0">Manage effective tax rules, scope, priority and category mapping.</p>
        </div>
        <button class="btn btn-primary" id="tax-rules-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    </div>

    <div id="tax-rules-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-rules-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Country</th>
                            <th>State</th>
                            <th>Category</th>
                            <th>Rate</th>
                            <th>Effective Range</th>
                            <th>Priority</th>
                        </tr>
                    </thead>
                    <tbody id="tax-rules-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

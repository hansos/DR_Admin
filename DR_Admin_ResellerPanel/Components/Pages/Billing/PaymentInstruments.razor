@page "/billing/payment-instruments"

<div id="payment-instruments-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-wallet2"></i> Payment Instruments</h2>
            <p class="text-muted mb-0">Manage payment instruments used to map user choices to default gateways.</p>
        </div>
        <button class="btn btn-primary" id="payment-instruments-create" type="button">
            <i class="bi bi-plus-circle"></i> New Payment Instrument
        </button>
    </div>

    <div id="payment-instruments-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="payment-instruments-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Instruments</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Active</th>
                            <th>Sort</th>
                            <th>Default Gateway</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="payment-instruments-table-body">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="payment-instruments-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="payment-instruments-modal-title">New Payment Instrument</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="payment-instruments-form" novalidate>
                    <div class="mb-3">
                        <label for="payment-instruments-code" class="form-label">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="payment-instruments-code" placeholder="e.g. CreditCard">
                    </div>
                    <div class="mb-3">
                        <label for="payment-instruments-name" class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="payment-instruments-name" placeholder="e.g. Credit Card">
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="payment-instruments-sort-order" class="form-label">Sort order <span class="text-danger">*</span></label>
                            <input type="number" min="0" class="form-control" id="payment-instruments-sort-order" placeholder="10">
                        </div>
                        <div class="col-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="payment-instruments-is-active" checked>
                                <label class="form-check-label" for="payment-instruments-is-active">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="payment-instruments-default-gateway-id" class="form-label">Default gateway</label>
                        <select class="form-select" id="payment-instruments-default-gateway-id">
                            <option value="">No default gateway</option>
                        </select>
                    </div>
                    <div class="mt-3">
                        <label for="payment-instruments-description" class="form-label">Description</label>
                        <textarea class="form-control" id="payment-instruments-description" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="payment-instruments-save">
                    <i class="bi bi-check-lg"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="payment-instruments-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete payment instrument <strong id="payment-instruments-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="payment-instruments-confirm-delete">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

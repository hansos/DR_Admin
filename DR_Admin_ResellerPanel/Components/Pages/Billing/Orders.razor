@page "/billing/orders"

<div id="orders-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-cart-check"></i> Orders</h2>
            <p class="text-muted mb-0">Review and track all orders.</p>
        </div>

<style>
    #orders-table-body tr[data-order-id] {
        cursor: pointer;
        transition: background-color .15s ease-in-out;
    }

    #orders-table-body tr[data-order-id]:hover {
        background-color: #f3f8ff;
    }

    #orders-table-body tr.orders-row-selected {
        background-color: #e6f0ff;
    }
</style>
    </div>

    <div id="orders-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="orders-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="orders-filter-status">Status</label>
                    <select class="form-select" id="orders-filter-status">
                        <option value="">Any</option>
                        <option value="Pending">Pending</option>
                        <option value="Active">Active</option>
                        <option value="Suspended">Suspended</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Expired">Expired</option>
                        <option value="Trial">Trial</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="orders-filter-type">Type</label>
                    <select class="form-select" id="orders-filter-type">
                        <option value="">Any</option>
                        <option value="New">New</option>
                        <option value="Renewal">Renewal</option>
                        <option value="Upgrade">Upgrade</option>
                        <option value="Downgrade">Downgrade</option>
                        <option value="Addon">Addon</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="orders-filter-customerid">Customer ID</label>
                    <input class="form-control" id="orders-filter-customerid" type="number" min="1" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2 ms-auto">
                    <label class="form-label mb-1" for="orders-page-size">Page size</label>
                    <select class="form-select" id="orders-page-size">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-primary" id="orders-apply" type="button"><i class="bi bi-funnel"></i> Apply</button>
                    <button class="btn btn-outline-secondary" id="orders-reset" type="button"><i class="bi bi-x-circle"></i> Reset</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Recurring</th>
                            <th>Created</th>
                            <th>Next Billing</th>
                        </tr>
                    </thead>
                    <tbody id="orders-table-body">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="text-muted small" id="orders-pagination-info"></div>
                <div id="orders-paging-controls" class="mt-3">
                    <nav aria-label="Orders pagination">
                        <ul class="pagination justify-content-center mb-0" id="orders-paging-controls-list"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

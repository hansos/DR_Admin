@page "/billing/payments"

<div id="payments-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-cash-coin"></i> Payments</h2>
            <p class="text-muted mb-0">Review payment transactions and invoice allocations.</p>
        </div>
    </div>

    <div id="payments-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="payments-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="payments-filter-status">Status</label>
                    <select class="form-select" id="payments-filter-status">
                        <option value="">Any</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Completed">Completed</option>
                        <option value="Failed">Failed</option>
                        <option value="Refunded">Refunded</option>
                        <option value="PartiallyRefunded">Partially Refunded</option>
                        <option value="Disputed">Disputed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="payments-filter-customerid">Customer ID</label>
                    <input class="form-control" id="payments-filter-customerid" type="number" min="1" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="payments-filter-invoiceid">Invoice ID</label>
                    <input class="form-control" id="payments-filter-invoiceid" type="number" min="1" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2 ms-auto">
                    <label class="form-label mb-1" for="payments-page-size">Page size</label>
                    <select class="form-select" id="payments-page-size">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-primary" id="payments-apply" type="button"><i class="bi bi-funnel"></i> Apply</button>
                    <button class="btn btn-outline-secondary" id="payments-reset" type="button"><i class="bi bi-x-circle"></i> Reset</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Transaction</th>
                            <th>Invoice</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Method</th>
                            <th>Amount</th>
                            <th>Processed</th>
                        </tr>
                    </thead>
                    <tbody id="payments-table-body">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="text-muted small" id="payments-pagination-info"></div>
                <div id="payments-paging-controls" class="mt-3">
                    <nav aria-label="Payments pagination">
                        <ul class="pagination justify-content-center mb-0" id="payments-paging-controls-list"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

@page "/billing/tax-registrations"

<div id="tax-registrations-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-file-earmark-text"></i> Tax Registrations</h2>
            <p class="text-muted mb-0">Manage seller VAT/TAX registrations by legal entity and jurisdiction.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="tax-registrations-create" type="button"><i class="bi bi-plus-circle"></i> New</button>
            <button class="btn btn-outline-primary" id="tax-registrations-refresh" type="button"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
    </div>

    <div id="tax-registrations-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tax-registrations-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Jurisdiction</th>
                            <th>Registration Number</th>
                            <th>Effective From</th>
                            <th>Effective To</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tax-registrations-table-body">
                        <tr>
                            <td colspan="7" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-registrations-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tax-registrations-modal-title">New Tax Registration</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tax-registrations-form" novalidate>
                    <div class="mb-3">
                        <label for="tax-registrations-jurisdiction" class="form-label">Jurisdiction <span class="text-danger">*</span></label>
                        <select class="form-select" id="tax-registrations-jurisdiction"></select>
                    </div>
                    <div class="mb-3">
                        <label for="tax-registrations-entity" class="form-label">Legal entity <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tax-registrations-entity" />
                    </div>
                    <div class="mb-3">
                        <label for="tax-registrations-number" class="form-label">Registration number <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="tax-registrations-number" />
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="tax-registrations-from" class="form-label">Effective from <span class="text-danger">*</span></label>
                            <input type="datetime-local" class="form-control" id="tax-registrations-from" />
                        </div>
                        <div class="col-6">
                            <label for="tax-registrations-until" class="form-label">Effective until</label>
                            <input type="datetime-local" class="form-control" id="tax-registrations-until" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex align-items-center justify-content-between">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="tax-registrations-is-active" checked />
                            <label class="form-check-label" for="tax-registrations-is-active">Active</label>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="tax-registrations-notes" class="form-label">Notes</label>
                        <textarea class="form-control" id="tax-registrations-notes" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="tax-registrations-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tax-registrations-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete registration <strong id="tax-registrations-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="tax-registrations-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

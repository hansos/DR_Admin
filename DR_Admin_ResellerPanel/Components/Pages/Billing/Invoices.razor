@page "/billing/invoices"

<div id="invoices-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-receipt"></i> Invoices</h2>
            <p class="text-muted mb-0">Review and track all invoices.</p>
        </div>
    </div>

    <div id="invoices-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="invoices-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="invoices-filter-status">Status</label>
                    <select class="form-select" id="invoices-filter-status">
                        <option value="">Any</option>
                        <option value="Draft">Draft</option>
                        <option value="Issued">Issued</option>
                        <option value="Paid">Paid</option>
                        <option value="Overdue">Overdue</option>
                        <option value="Cancelled">Cancelled</option>
                        <option value="Credited">Credited</option>
                    </select>
                </div>

<style>
    #invoices-table-body tr[data-invoice-id] {
        cursor: pointer;
        transition: background-color .15s ease-in-out;
    }

    #invoices-table-body tr[data-invoice-id]:hover > td {
        background-color: #f3f8ff;
    }

    #invoices-table-body tr.invoices-row-selected > td {
        background-color: #e6f0ff;
    }

    #invoices-table-body tr.invoices-row-drilldown > td {
        background-color: #f8f9fc;
    }
</style>

                <div class="col-12 col-md-2">
                    <label class="form-label mb-1" for="invoices-filter-customerid">Customer ID</label>
                    <input class="form-control" id="invoices-filter-customerid" type="number" min="1" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2 ms-auto">
                    <label class="form-label mb-1" for="invoices-page-size">Page size</label>
                    <select class="form-select" id="invoices-page-size">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                        <option value="100">100</option>
                    </select>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-primary" id="invoices-apply" type="button"><i class="bi bi-funnel"></i> Apply</button>
                    <button class="btn btn-outline-secondary" id="invoices-reset" type="button"><i class="bi bi-x-circle"></i> Reset</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Invoice #</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Issue Date</th>
                            <th>Due Date</th>
                            <th>Total</th>
                            <th>Amount Due</th>
                        </tr>
                    </thead>
                    <tbody id="invoices-table-body">
                        <tr>
                            <td colspan="8" class="text-center">
                                <div class="spinner-border text-primary"></div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div class="text-muted small" id="invoices-pagination-info"></div>
                <div id="invoices-paging-controls" class="mt-3">
                    <nav aria-label="Invoices pagination">
                        <ul class="pagination justify-content-center mb-0" id="invoices-paging-controls-list"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

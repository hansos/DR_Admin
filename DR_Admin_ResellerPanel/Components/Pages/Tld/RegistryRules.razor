@page "/tld/registry-rules"

<div id="tld-registry-rules-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-journal-check"></i> TLD Registry Rules</h2>
            <p class="text-muted mb-0">Manage per-TLD policy and compliance rules.</p>
        </div>
        <button class="btn btn-primary" id="tld-registry-rules-create" type="button">
            <i class="bi bi-plus-circle"></i> New Rule
        </button>
    </div>

    <div id="tld-registry-rules-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="tld-registry-rules-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Registry Rules</h5>
            <button class="btn btn-sm btn-outline-primary" id="tld-registry-rules-refresh" type="button">
                <i class="bi bi-arrow-repeat"></i> Refresh
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>TLD</th>
                            <th>Contacts</th>
                            <th>Transfer</th>
                            <th>Grace periods</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tld-registry-rules-table-body">
                        <tr><td colspan="6" class="text-center"><div class="spinner-border text-primary"></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tld-registry-rules-edit-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="tld-registry-rules-modal-title">New Registry Rule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="tld-registry-rules-form" novalidate>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="tld-registry-rules-tld-id">TLD <span class="text-danger">*</span></label>
                            <select class="form-select" id="tld-registry-rules-tld-id"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="tld-registry-rules-transfer-lock-days">Transfer lock (days)</label>
                            <input type="number" class="form-control" id="tld-registry-rules-transfer-lock-days" min="0" max="3650" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="tld-registry-rules-is-active">Status</label>
                            <select class="form-select" id="tld-registry-rules-is-active">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label" for="tld-registry-rules-renewal-grace-days">Renewal grace (days)</label>
                            <input type="number" class="form-control" id="tld-registry-rules-renewal-grace-days" min="0" max="3650" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="tld-registry-rules-redemption-grace-days">Redemption grace (days)</label>
                            <input type="number" class="form-control" id="tld-registry-rules-redemption-grace-days" min="0" max="3650" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="tld-registry-rules-requires-auth-code" />
                                <label class="form-check-label" for="tld-registry-rules-requires-auth-code">Requires auth code for transfer</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex flex-wrap gap-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="tld-registry-rules-require-registrant" />
                                    <label class="form-check-label" for="tld-registry-rules-require-registrant">Require registrant contact</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="tld-registry-rules-require-admin" />
                                    <label class="form-check-label" for="tld-registry-rules-require-admin">Require admin contact</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="tld-registry-rules-require-tech" />
                                    <label class="form-check-label" for="tld-registry-rules-require-tech">Require technical contact</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="tld-registry-rules-require-billing" />
                                    <label class="form-check-label" for="tld-registry-rules-require-billing">Require billing contact</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="tld-registry-rules-notes">Notes</label>
                            <textarea class="form-control" id="tld-registry-rules-notes" rows="3" maxlength="2000"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="tld-registry-rules-save"><i class="bi bi-check-lg"></i> Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="tld-registry-rules-delete-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Delete registry rule for <strong id="tld-registry-rules-delete-name"></strong>?</p>
                <p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> This cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="tld-registry-rules-confirm-delete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

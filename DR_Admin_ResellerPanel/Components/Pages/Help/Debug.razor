@page "/help/debug"

<div id="help-debug-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-bug"></i> Debug</h2>
            <p class="text-muted mb-0">Debug-only diagnostics for API build mode.</p>
        </div>
        <button id="help-debug-refresh" class="btn btn-outline-secondary" type="button">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <div id="help-debug-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="help-debug-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-wrench-adjustable-circle"></i> Build Mode</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Mode</dt>
                <dd class="col-sm-9" id="help-debug-build-mode">-</dd>

                <dt class="col-sm-3">Is Debug</dt>
                <dd class="col-sm-9" id="help-debug-build-flag">-</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-save2"></i> Admin User + MyCompany Snapshot</h5>
        </div>
        <div class="card-body">
            <div class="row g-2 align-items-end mb-3">
                <div class="col-md-6">
                    <label class="form-label" for="help-debug-snapshot-file">Snapshot file name</label>
                    <input id="help-debug-snapshot-file" class="form-control" type="text" placeholder="admin-mycompany-debug.json" />
                </div>
                <div class="col-md-6 d-flex gap-2">
                    <button id="help-debug-export-snapshot" class="btn btn-primary" type="button">
                        <i class="bi bi-download"></i> Export Snapshot
                    </button>
                </div>
            </div>

            <dl class="row mb-0">
                <dt class="col-sm-3">Last Snapshot File</dt>
                <dd class="col-sm-9" id="help-debug-snapshot-last-file">-</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-database-add"></i> Seed Test Data</h5>
            <button id="help-debug-seed-test-data" class="btn btn-outline-primary" type="button">
                <i class="bi bi-database-add"></i> Seed Test Data
            </button>
        </div>
        <div class="card-body">
            <p class="mb-0 text-muted">Insert debug test data into empty catalog tables.</p>
        </div>
    </div>
</div>

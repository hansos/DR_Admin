@page "/domains/registrants"

<div id="domain-registrants-page" class="container-fluid">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
            <h2 class="h4 mb-1"><i class="bi bi-person-vcard"></i> Domain Registrants</h2>
            <p class="text-muted mb-0">Read-only registrant list from all active registrars.</p>
        </div>
        <button class="btn btn-outline-primary" id="domain-registrants-refresh" type="button">
            <i class="bi bi-arrow-repeat"></i> Refresh
        </button>
    </div>

    <div id="domain-registrants-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="domain-registrants-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Registrants</h5>
            <span class="badge bg-primary" id="domain-registrants-count">0</span>
        </div>
        <div class="card-body">
            <div id="domain-registrants-loading" class="text-center py-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted mb-0">Loading registrants...</p>
            </div>

            <div id="domain-registrants-content" class="d-none">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Organization</th>
                                <th>First name</th>
                                <th>Last name</th>
                                <th>Email</th>
                                <th>Email in customers</th>
                                <th>Country code</th>
                                <th>Registrar</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="domain-registrants-table-body">
                            <tr><td colspan="8" class="text-center text-muted">No registrants found.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="domain-registrants-company-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add as Contact Person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-2">Select company/customer to attach this registrant contact to.</p>
                <div class="small mb-2"><strong>Registrant:</strong> <span id="domain-registrants-selected-email">-</span></div>
                <select class="form-select" id="domain-registrants-company-select">
                    <option value="">Select company</option>
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="domain-registrants-add-contact-confirm">
                    <i class="bi bi-person-plus"></i> Add contact person
                </button>
            </div>
        </div>
    </div>
</div>

    <ProjectReference Include="..\EmailSenderProviders\EmailSenderProvider.AmazonSes\EmailSenderProvider.AmazonSes.csproj" />
    <ProjectReference Include="..\EmailSenderProviders\EmailSenderProvider.Postmark\EmailSenderProvider.Postmark.csproj" />

    <ProjectReference Include="..\HostingPanelLib\HostingPanelLib.csproj" />
    <ProjectReference Include="..\PaymentGatewayLib\PaymentGatewayLib.csproj" />
    <ProjectReference Include="..\ReportGeneratorLib\ReportGeneratorLib.csproj" />

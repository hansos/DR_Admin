@inherits LayoutComponentBase

<div class="public-page">
    <header class="public-top-row">
        <div class="public-top-row-inner px-4">
            <a class="public-brand" href="/">DR Admin Shop</a>
            <div class="public-links">
                <a href="/about-public" class="text-decoration-none">About</a>
                <a id="public-auth-link" href="/account/login" class="top-auth-logout"><i class="bi bi-box-arrow-in-right"></i>&nbsp;Sign in</a>
            </div>
        </div>
    </header>

    <main class="public-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

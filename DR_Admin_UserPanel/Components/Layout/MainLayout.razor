@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <div class="sidebar-brand px-3">
            <a class="navbar-brand" href="/"></a>
        </div>

        <nav class="nav-scrollable" id="user-menu">
            <div class="nav-group" data-section="shop">
                <button class="nav-group-header" type="button">
                    <span><i class="bi bi-bag nav-icon"></i>&nbsp;Shop</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/shop/domain-search" class="nav-link-item">Domain Search</a>
                    <a href="/shop/checkout" class="nav-link-item">Checkout</a>
                </div>
            </div>

            <div class="nav-group" data-section="services">
                <button class="nav-group-header" type="button">
                    <span><i class="bi bi-box-seam nav-icon"></i>&nbsp;My Services</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/domains" class="nav-link-item">Domains</a>
                    <a href="/hosting" class="nav-link-item">Hosting</a>
                    <a href="/services/add-ons" class="nav-link-item">Add-ons / SSL / Services</a>
                </div>
            </div>

            <div class="nav-group" data-section="billing">
                <button class="nav-group-header" type="button">
                    <span><i class="bi bi-credit-card nav-icon"></i>&nbsp;Billing</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/billing/invoices" class="nav-link-item"><i class="bi bi-file-earmark-text nav-icon"></i>&nbsp;Invoices</a>
                    <a href="/billing/orders" class="nav-link-item"><i class="bi bi-receipt nav-icon"></i>&nbsp;Orders</a>
                    <a href="/billing/renewals" class="nav-link-item">Renewals</a>
                    <a href="/billing/payment-methods" class="nav-link-item">Payment Methods</a>
                    <a href="/billing/wallet" class="nav-link-item">Wallet</a>
                </div>
            </div>

            <div class="nav-group" data-section="account">
                <button class="nav-group-header" type="button">
                    <span><i class="bi bi-person nav-icon"></i>&nbsp;Account</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/account/customer-page" class="nav-link-item">My Company</a>
                    <a href="/contacts" class="nav-link-item">Contacts</a>
                    <a href="/security/sessions" class="nav-link-item">Security</a>
                    <a href="/security/2fa" class="nav-link-item"><i class="bi bi-shield-lock nav-icon"></i>&nbsp;Two-Factor Auth</a>
                    <a href="/settings/notifications" class="nav-link-item">Notifications</a>
                </div>
            </div>

            <div class="nav-group nav-group-actions" data-section="help">
                <button class="nav-group-header" type="button">
                    <span><i class="bi bi-life-preserver nav-icon"></i>&nbsp;Help</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/about" class="nav-link-item">About</a>
                    <a href="/support/tickets" class="nav-link-item">Support</a>
                    <a href="/support/communication" class="nav-link-item"><i class="bi bi-chat-dots nav-icon"></i>&nbsp;Communication</a>
                </div>
            </div>
        </nav>
    </aside>

    <main>
        <div class="top-row px-4">
            <div id="top-auth-info" class="top-auth-info d-none">
                <div class="dropdown">
                    <button class="btn btn-link top-auth-user dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle"></i>&nbsp;<span id="top-auth-username"></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/account/settings">Edit account settings</a></li>
                        <li><a class="dropdown-item" href="/account/change-password">Change password</a></li>
                        <li><a class="dropdown-item" href="/account/customer-page">Edit my company</a></li>
                    </ul>
                </div>
                <a href="#" id="top-auth-logout" class="top-auth-logout"><i class="bi bi-box-arrow-in-right"></i>&nbsp;Sign out</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

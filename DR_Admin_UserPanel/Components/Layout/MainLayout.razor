@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <div class="sidebar-brand px-3">
            <a class="navbar-brand" href="/">DR User Panel</a>
        </div>

        <nav class="nav-scrollable" id="user-menu">
            <div class="nav-group" data-section="overview">
                <button class="nav-group-header" type="button">
                    <span>Overview</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/dashboard" class="nav-link-item">Dashboard</a>
                    <a href="/activity" class="nav-link-item">Activity</a>
                    <a href="/settings/notifications" class="nav-link-item">Notifications</a>
                </div>
            </div>

            <div class="nav-group" data-section="products">
                <button class="nav-group-header" type="button">
                    <span>Products</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/domains" class="nav-link-item">Domains</a>
                    <a href="/hosting" class="nav-link-item">Hosting</a>
                    <a href="/contacts" class="nav-link-item">Contacts</a>
                </div>
            </div>

            <div class="nav-group" data-section="billing">
                <button class="nav-group-header" type="button">
                    <span>Billing</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/billing/invoices" class="nav-link-item">Invoices</a>
                    <a href="/billing/renewals" class="nav-link-item">Renewals</a>
                    <a href="/billing/payment-methods" class="nav-link-item">Payment Methods</a>
                    <a href="/billing/wallet" class="nav-link-item">Wallet</a>
                </div>
            </div>

            <div class="nav-group" data-section="security">
                <button class="nav-group-header" type="button">
                    <span>Security &amp; Privacy</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/security/2fa" class="nav-link-item">2FA</a>
                    <a href="/security/sessions" class="nav-link-item">Sessions</a>
                    <a href="/privacy" class="nav-link-item">Privacy</a>
                </div>
            </div>

            <div class="nav-group" data-section="shop">
                <button class="nav-group-header" type="button">
                    <span>Shop</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/shop/domain-search" class="nav-link-item">Domain Search</a>
                    <a href="/shop/cart" class="nav-link-item">Cart</a>
                    <a href="/shop/checkout" class="nav-link-item">Checkout</a>
                </div>
            </div>

            <div class="nav-group nav-group-actions" data-section="support">
                <button class="nav-group-header" type="button">
                    <span>Support</span>
                    <i class="bi bi-chevron-down nav-chevron"></i>
                </button>
                <div class="nav-subitems">
                    <a href="/support/tickets" class="nav-link-item">Support</a>
                    <button class="nav-link-item nav-link-button" id="global-logout" type="button">Logout</button>
                </div>
            </div>
        </nav>
    </aside>

    <main>
        <div class="top-row px-4">
            <span>User Panel</span>
            <div id="top-auth-info" class="top-auth-info d-none">
                <span id="top-auth-username"></span>
                <a href="#" id="top-auth-logout" class="top-auth-logout">Logout</a>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@page "/security/2fa"

<PageTitle>Two-Factor Authentication</PageTitle>

<div class="container py-4" id="security-2fa-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Two-Factor Authentication</h1>
            <p class="text-muted mb-0">Manage additional sign-in verification and email verification status.</p>
        </div>
    </div>

    <div id="security-2fa-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="security-2fa-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="row g-3">
        <div class="col-12 col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header">Account security</div>
                <div class="card-body">
                    <div id="security-2fa-account-summary" class="small text-muted">Loading account details...</div>
                    <hr />
                    <div id="security-2fa-email-status" class="small"></div>
                    <div class="mt-2">
                        <button id="security-2fa-send-verification" class="btn btn-sm btn-outline-primary d-none" type="button">
                            Send verification email
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-header">2FA settings</div>
                <div class="card-body">
                    <form id="security-2fa-form" novalidate>
                        <div id="security-2fa-definition-controls">
                            <div class="form-check form-switch mb-2">
                                <input id="security-2fa-enabled" class="form-check-input" type="checkbox" />
                                <label for="security-2fa-enabled" class="form-check-label">Enable two-factor authentication</label>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Verification method</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="security-2fa-method" id="security-2fa-method-email" value="Email" checked />
                                    <label class="form-check-label" for="security-2fa-method-email">Email code</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="security-2fa-method" id="security-2fa-method-authenticator" value="Authenticator" />
                                    <label class="form-check-label" for="security-2fa-method-authenticator">Microsoft Authenticator</label>
                                </div>
                            </div>

                            <div id="security-2fa-authenticator-panel" class="border rounded p-3 mb-3 d-none">
                                <p class="small text-muted mb-2">Scan the QR code in Microsoft Authenticator or enter the setup key manually.</p>
                                <div id="security-2fa-qr-wrapper" class="mb-2 d-none">
                                    <img id="security-2fa-qr-image" class="img-thumbnail" alt="Authenticator QR code" />
                                </div>
                                <div id="security-2fa-manual-key" class="small mb-3 text-break"></div>

                                <div id="security-2fa-authenticator-setup-controls">
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                    <button id="security-2fa-setup-authenticator" class="btn btn-sm btn-outline-primary" type="button">Generate QR code</button>
                                    </div>

                                    <div class="input-group input-group-sm">
                                        <input id="security-2fa-authenticator-code" class="form-control" type="text" maxlength="6" placeholder="Enter 6-digit code" />
                                        <button id="security-2fa-confirm-authenticator" class="btn btn-success" type="button">Confirm app</button>
                                    </div>
                                </div>

                                <div id="security-2fa-next-step" class="alert alert-info d-none mt-3 mb-0" role="status"></div>
                            </div>

                            <button id="security-2fa-save" class="btn btn-primary" type="submit">Save security setting</button>
                        </div>

                        <div id="security-2fa-status" class="text-muted small mb-3">Loading 2FA status...</div>

                        <div id="security-2fa-existing-actions" class="d-none">
                            <div class="d-flex flex-wrap gap-2">
                                <button id="security-2fa-enable-existing" class="btn btn-primary d-none" type="button">Enable 2FA</button>
                                <button id="security-2fa-disable-existing" class="btn btn-outline-warning" type="button">Disable 2FA</button>
                                <button id="security-2fa-delete-existing" class="btn btn-outline-danger" type="button">Delete 2FA setup</button>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Disable keeps your setup for later use. Delete removes all saved 2FA setup details.</p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

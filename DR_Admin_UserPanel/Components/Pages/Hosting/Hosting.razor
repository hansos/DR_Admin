@page "/hosting"

<PageTitle>Hosting</PageTitle>

<div class="container py-4" id="hosting-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">My Hosting Subscriptions</h1>
            <p class="text-muted mb-0">Review your hosting accounts, status and plan information.</p>
        </div>
    </div>

    <div id="hosting-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="hosting-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label for="hosting-filter-status" class="form-label mb-1">Status</label>
                    <input id="hosting-filter-status" class="form-control" type="text" placeholder="Any" />
                </div>
                <div class="col-12 col-md-3">
                    <label for="hosting-filter-cycle" class="form-label mb-1">Billing cycle</label>
                    <input id="hosting-filter-cycle" class="form-control" type="text" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2">
                    <label for="hosting-page-size" class="form-label mb-1">Page size</label>
                    <select id="hosting-page-size" class="form-select">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-12 col-md-3 d-flex justify-content-md-end gap-2">
                    <button id="hosting-apply" class="btn btn-outline-primary" type="button">Apply</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Status</th>
                            <th>Billing</th>
                            <th>Price</th>
                            <th>Next Billing</th>
                            <th>Expires</th>
                            <th>Auto renew</th>
                            <th>Order</th>
                        </tr>
                    </thead>
                    <tbody id="hosting-table-body">
                        <tr><td colspan="8" class="text-center text-muted">Loading hosting subscriptions...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div id="hosting-pagination-info" class="small text-muted"></div>
                <div class="d-flex gap-2">
                    <button id="hosting-prev" class="btn btn-sm btn-outline-secondary" type="button">Previous</button>
                    <button id="hosting-next" class="btn btn-sm btn-outline-secondary" type="button">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

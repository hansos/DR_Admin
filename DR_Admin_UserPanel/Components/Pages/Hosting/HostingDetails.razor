@page "/hosting/details"

<PageTitle>Hosting Details</PageTitle>

<div class="container py-4" id="hosting-details-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Hosting Details</h1>
            <p class="text-muted mb-0">Status, resources, SSL and lifecycle actions.</p>
        </div>
        <a href="/hosting" class="btn btn-outline-secondary btn-sm">Back to hosting</a>
    </div>

    <div id="hosting-details-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="hosting-details-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div id="hosting-details-summary" class="text-muted">Loading hosting details...</div>
            <div class="mt-3 d-flex flex-wrap gap-2">
                <button id="hosting-details-suspend" class="btn btn-outline-warning btn-sm" type="button">Set status: Suspended</button>
                <button id="hosting-details-reactivate" class="btn btn-outline-success btn-sm" type="button">Set status: Active</button>
                <button id="hosting-details-upgrade" class="btn btn-outline-primary btn-sm" type="button">Upgrade plan (+10%)</button>
                <button id="hosting-details-downgrade" class="btn btn-outline-secondary btn-sm" type="button">Downgrade plan (-10%)</button>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">SSL and resources</div>
        <div class="card-body">
            <div id="hosting-details-resources" class="text-muted">No resource data loaded yet.</div>
        </div>
    </div>
</div>

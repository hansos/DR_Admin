@page "/"
@layout Layout.PublicLayout

<PageTitle>DR User Panel</PageTitle>

<div class="container py-5" id="home-page">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 mb-3">Welcome to DR User Panel</h1>
                    <p class="text-muted mb-4">Phase-1 MVP foundation is in progress. Use the links below to start the authentication and shopping flow.</p>

                    <div class="d-flex flex-wrap gap-2">
                        <a href="/account/register" class="btn btn-primary">Create account</a>
                        <a href="/account/login" class="btn btn-outline-primary">Sign in</a>
                        <a href="/shop/domain-search" class="btn btn-outline-secondary">Search domain</a>
                        <a href="/dashboard" class="btn btn-outline-secondary">View dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@page "/about"

<PageTitle>About</PageTitle>

<div class="container py-4" id="about-page">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="card shadow-sm mb-3">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">About DR User Panel</h1>
                    <p class="text-muted mb-0">
                        DR User Panel is a customer-facing portal for managing domains, hosting services, billing, account security, and support requests.
                        It provides self-service tools for day-to-day account operations and purchasing workflows.
                    </p>
                    <p class="mt-3 mb-0">
                        Project home page: <a href="https://www.dradmin.net/" target="_blank" rel="noopener noreferrer">https://www.dradmin.net/</a>
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header">License Summary</div>
                <div class="card-body p-4">
                    <p class="mb-2">This application uses a dual-license model.</p>
                    <ul class="mb-3">
                        <li>The application can be used under the AGPL-3.0-only license if annual revenue is under 1,000,000 Euro.</li>
                        <li>For commercial use outside this scope, a separate commercial license is required.</li>
                    </ul>

                    <p class="mb-1">License documents on GitHub:</p>
                    <ul class="mb-0">
                        <li><a href="https://github.com/hansos/DR_Admin/blob/master/LICENSE.txt" target="_blank" rel="noopener noreferrer">LICENSE.txt</a></li>
                        <li><a href="https://github.com/hansos/DR_Admin/blob/master/LICENSE-SUMMARY.md" target="_blank" rel="noopener noreferrer">LICENSE-SUMMARY.md</a></li>
                        <li><a href="https://github.com/hansos/DR_Admin/blob/master/COMMERCIAL-LICENSE.md" target="_blank" rel="noopener noreferrer">COMMERCIAL-LICENSE.md</a></li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">Server libraries</div>
                <div class="card-body p-4">
                    <p class="mb-2">
                        DR Admin server applications use Serilog and QuestPDF in the backend.
                    </p>
                    <p class="mb-0">
                        See full third-party details in
                        <a href="https://github.com/hansos/DR_Admin/blob/master/DR_Admin/CREDITS.md" target="_blank" rel="noopener noreferrer">Credits</a>.
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

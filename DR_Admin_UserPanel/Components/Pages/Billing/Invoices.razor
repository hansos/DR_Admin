@page "/billing/invoices"
@page "/invoices"

<PageTitle>Invoices</PageTitle>

<div class="container py-4" id="invoices-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Invoice History</h1>
            <p class="text-muted mb-0">Review invoices and payment state.</p>
        </div>
    </div>

    <div id="invoices-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="invoices-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <ul class="list-group list-group-flush" id="invoices-list">
                <li class="list-group-item text-center text-muted">Loading invoices...</li>
            </ul>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div id="invoices-pagination-info" class="small text-muted"></div>
                <div class="d-flex gap-2">
                    <button id="invoices-prev" class="btn btn-sm btn-outline-secondary" type="button">Previous</button>
                    <button id="invoices-next" class="btn btn-sm btn-outline-secondary" type="button">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

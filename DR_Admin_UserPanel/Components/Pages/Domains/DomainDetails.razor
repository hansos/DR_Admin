@page "/domains/details"

<PageTitle>Domain Details</PageTitle>

<div class="container py-4" id="domain-details-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Domain Details</h1>
            <p class="text-muted mb-0">View status, nameservers and transfer details.</p>
        </div>
        <a href="/domains" class="btn btn-outline-secondary btn-sm">Back to domains</a>
    </div>

    <div id="domain-details-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="domain-details-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div id="domain-details-summary" class="text-muted">Loading domain details...</div>
            <div class="mt-3 d-flex flex-wrap gap-2">
                <button id="domain-details-toggle-lock" class="btn btn-outline-primary btn-sm" type="button">Toggle lock</button>
                <button id="domain-details-copy-epp" class="btn btn-outline-secondary btn-sm" type="button">Copy EPP/Auth hint</button>
                <a id="domain-details-open-dns" href="/domains/dns" class="btn btn-outline-primary btn-sm">Open DNS manager</a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Nameservers</div>
        <div class="card-body">
            <ul id="domain-details-nameservers" class="mb-0"></ul>
        </div>
    </div>
</div>

@page "/domains"

<PageTitle>Domains</PageTitle>

<div class="container py-4" id="domains-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Domain Management</h1>
            <p class="text-muted mb-0">Review registered domains and open lifecycle tools.</p>
        </div>
    </div>

    <div id="domains-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="domains-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-light">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label for="domains-filter-search" class="form-label mb-1">Search</label>
                    <input id="domains-filter-search" class="form-control" type="text" placeholder="Domain name" />
                </div>
                <div class="col-12 col-md-3">
                    <label for="domains-filter-status" class="form-label mb-1">Status</label>
                    <input id="domains-filter-status" class="form-control" type="text" placeholder="Any" />
                </div>
                <div class="col-12 col-md-2">
                    <label for="domains-page-size" class="form-label mb-1">Page size</label>
                    <select id="domains-page-size" class="form-select">
                        <option value="10">10</option>
                        <option value="25" selected>25</option>
                        <option value="50">50</option>
                    </select>
                </div>
                <div class="col-12 col-md-3 d-flex justify-content-md-end gap-2">
                    <button id="domains-apply" class="btn btn-outline-primary" type="button">Apply</button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Domain</th>
                            <th>Status</th>
                            <th>Expires</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="domains-table-body">
                        <tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div id="domains-pagination-info" class="small text-muted"></div>
                <div class="d-flex gap-2">
                    <button id="domains-prev" class="btn btn-sm btn-outline-secondary" type="button">Previous</button>
                    <button id="domains-next" class="btn btn-sm btn-outline-secondary" type="button">Next</button>
                </div>
            </div>
        </div>
    </div>
</div>

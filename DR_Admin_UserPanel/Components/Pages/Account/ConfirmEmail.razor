@page "/my-account/confirm-email"
@layout Layout.PublicLayout

<PageTitle>Confirm Email</PageTitle>

<div class="container py-4" id="account-confirm-email-page">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">Confirm email</h1>

                    <div id="auth-confirm-email-alert-success" class="alert alert-success d-none" role="alert"></div>
                    <div id="auth-confirm-email-alert-error" class="alert alert-danger d-none" role="alert"></div>

                    <p id="auth-confirm-email-status" class="text-muted mb-3">
                        Confirm email for <strong id="auth-confirm-email-address">your account</strong>.
                    </p>

                    <div class="d-grid">
                        <button id="auth-confirm-email-submit" class="btn btn-primary" type="button">Confirm email</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

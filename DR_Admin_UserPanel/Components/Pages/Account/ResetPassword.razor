@page "/account/reset-password"
@page "/my-account/change-password"
@layout Layout.PublicLayout

<PageTitle>Reset Password</PageTitle>

<div class="container py-4" id="account-reset-password-page">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">Reset password</h1>

                    <div id="auth-reset-password-alert-success" class="alert alert-success d-none" role="alert"></div>
                    <div id="auth-reset-password-alert-error" class="alert alert-danger d-none" role="alert"></div>

                    <form id="auth-reset-password-form" novalidate>
                        <div class="mb-3">
                            <label for="auth-reset-password-new" class="form-label">New password</label>
                            <div class="input-group">
                                <input id="auth-reset-password-new" class="form-control" type="password" required />
                                <button id="auth-reset-password-toggle-new" class="btn btn-outline-secondary" type="button" aria-label="Show password">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="auth-reset-password-confirm" class="form-label">Confirm password</label>
                            <div class="input-group">
                                <input id="auth-reset-password-confirm" class="form-control" type="password" required />
                                <button id="auth-reset-password-toggle-confirm" class="btn btn-outline-secondary" type="button" aria-label="Show password">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-grid">
                            <button id="auth-reset-password-submit" class="btn btn-primary" type="submit">
                                <i class="bi bi-check-lg"></i> Reset password
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

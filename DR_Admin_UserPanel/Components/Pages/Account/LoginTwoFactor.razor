@page "/account/login-2fa"
@layout Layout.PublicLayout

<PageTitle>Two-Factor Verification</PageTitle>

<div class="container py-4" id="auth-login-2fa-page">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-2">Verify sign-in</h1>
                    <p id="auth-login-2fa-method-label" class="text-muted small mb-3">Enter your 6-digit verification code.</p>

                    <div id="auth-login-2fa-alert-success" class="alert alert-success d-none" role="alert"></div>
                    <div id="auth-login-2fa-alert-error" class="alert alert-danger d-none" role="alert"></div>

                    <form id="auth-login-2fa-form" novalidate>
                        <div class="mb-3">
                            <label for="auth-login-2fa-code" class="form-label">Verification code</label>
                            <input id="auth-login-2fa-code" class="form-control" type="text" maxlength="6" autocomplete="one-time-code" required />
                        </div>

                        <div class="d-grid gap-2 mb-3">
                            <button id="auth-login-2fa-submit" class="btn btn-primary" type="submit">Verify and sign in</button>
                            <button id="auth-login-2fa-resend" class="btn btn-outline-secondary" type="button">Resend code</button>
                        </div>

                        <div class="small">
                            <a href="/account/login">Back to login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

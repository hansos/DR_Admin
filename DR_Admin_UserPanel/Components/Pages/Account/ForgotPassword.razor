@page "/account/forgot-password"
@layout Layout.PublicLayout

<PageTitle>Forgot Password</PageTitle>

<div class="container py-4" id="account-forgot-password-page">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h1 class="h4 mb-3">Forgot password</h1>
                    <p class="text-muted">Enter your account email to request a reset link.</p>

                    <div id="auth-forgot-password-alert-success" class="alert alert-success d-none" role="alert"></div>
                    <div id="auth-forgot-password-alert-error" class="alert alert-danger d-none" role="alert"></div>

                    <form id="auth-forgot-password-form" novalidate>
                        <div class="mb-3">
                            <label for="auth-forgot-password-email" class="form-label">Email</label>
                            <input id="auth-forgot-password-email" class="form-control" type="email" required />
                        </div>
                        <div id="auth-forgot-password-submit-container" class="d-grid">
                            <button id="auth-forgot-password-submit" class="btn btn-primary" type="submit">
                                <i class="bi bi-send"></i> Send reset link
                            </button>
                        </div>
                        <div id="auth-forgot-password-post-actions" class="d-none mt-2 d-flex gap-2">
                            <button id="auth-forgot-password-retry" class="btn btn-outline-primary flex-fill" type="button">
                                <i class="bi bi-arrow-clockwise"></i> Retry
                            </button>
                            <a id="auth-forgot-password-goto-login" href="/account/login" class="btn btn-primary flex-fill">
                                <i class="bi bi-box-arrow-in-right"></i> Go to login
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

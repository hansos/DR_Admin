@page "/account/change-password"

<PageTitle>Change Password</PageTitle>

<div class="container py-4" id="account-change-password-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Change Password</h1>
            <p class="text-muted mb-0">Set a new password for your account.</p>
        </div>
    </div>

    <div id="account-change-password-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="account-change-password-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form id="account-change-password-form" class="row g-3" novalidate>
                <div class="col-12">
                    <label for="account-change-password-current" class="form-label">Current password</label>
                    <input id="account-change-password-current" class="form-control" type="password" required />
                </div>
                <div class="col-12 col-md-6">
                    <label for="account-change-password-new" class="form-label">New password</label>
                    <input id="account-change-password-new" class="form-control" type="password" minlength="8" required />
                </div>
                <div class="col-12 col-md-6">
                    <label for="account-change-password-confirm" class="form-label">Confirm new password</label>
                    <input id="account-change-password-confirm" class="form-control" type="password" minlength="8" required />
                </div>
                <div class="col-12 d-flex justify-content-end">
                    <button id="account-change-password-save" class="btn btn-primary" type="submit">Update password</button>
                </div>
            </form>
        </div>
    </div>
</div>

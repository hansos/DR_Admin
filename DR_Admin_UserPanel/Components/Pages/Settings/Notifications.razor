@page "/settings/notifications"

<PageTitle>Notifications</PageTitle>

<div class="container py-4" id="notifications-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Notification Settings</h1>
            <p class="text-muted mb-0">Configure reminders and view in-app alert center.</p>
        </div>
    </div>

    <div id="notifications-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="notifications-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form id="notifications-form" class="row g-3" novalidate>
                <div class="col-12 col-md-4">
                    <div class="form-check form-switch">
                        <input id="notifications-renewal-reminder" class="form-check-input" type="checkbox" checked />
                        <label for="notifications-renewal-reminder" class="form-check-label">Renewal reminders</label>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="form-check form-switch">
                        <input id="notifications-payment-reminder" class="form-check-input" type="checkbox" checked />
                        <label for="notifications-payment-reminder" class="form-check-label">Payment reminders</label>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex align-items-end justify-content-md-end">
                    <button id="notifications-save" class="btn btn-primary" type="submit">Save preferences</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">In-app alerts</div>
        <div class="card-body" id="notifications-list">
            <div class="text-muted">Loading alerts...</div>
        </div>
    </div>
</div>

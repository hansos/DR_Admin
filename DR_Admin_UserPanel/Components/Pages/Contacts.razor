@page "/contacts"

<PageTitle>Contacts</PageTitle>

<div class="container py-4" id="contact-persons-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Contact Persons</h1>
            <p class="text-muted mb-0">Manage billing, technical and administrative contacts.</p>
        </div>
    </div>

    <div id="contact-persons-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="contact-persons-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form id="contact-persons-form" class="row g-2" novalidate>
                <input id="contact-persons-id" type="hidden" />
                <div class="col-12 col-md-2">
                    <input id="contact-persons-first-name" class="form-control" type="text" placeholder="First name" />
                </div>
                <div class="col-12 col-md-2">
                    <input id="contact-persons-last-name" class="form-control" type="text" placeholder="Last name" />
                </div>
                <div class="col-12 col-md-3">
                    <input id="contact-persons-email" class="form-control" type="email" placeholder="Email" />
                </div>
                <div class="col-12 col-md-2">
                    <input id="contact-persons-phone" class="form-control" type="text" placeholder="Phone" />
                </div>
                <div class="col-12 col-md-3 d-flex gap-2 align-items-center">
                    <div class="form-check form-switch">
                        <input id="contact-persons-is-primary" class="form-check-input" type="checkbox" />
                        <label for="contact-persons-is-primary" class="form-check-label">Primary</label>
                    </div>
                    <button id="contact-persons-save" class="btn btn-primary btn-sm" type="submit">Save</button>
                    <button id="contact-persons-reset" class="btn btn-outline-secondary btn-sm" type="button">Reset</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Roles</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="contact-persons-table-body">
                        <tr><td colspan="5" class="text-center text-muted">Loading contacts...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@page "/dashboard"

<PageTitle>Dashboard</PageTitle>

<div class="container py-4" id="dashboard-summary-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Dashboard</h1>
            <p class="text-muted mb-0">Overview of active assets and renewals.</p>
        </div>
    </div>

    <div id="dashboard-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="dashboard-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Active domains</div>
                    <div class="fs-4 fw-semibold" id="dashboard-active-domains">0</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Active hosting</div>
                    <div class="fs-4 fw-semibold" id="dashboard-active-hosting">0</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Active services</div>
                    <div class="fs-4 fw-semibold" id="dashboard-active-services">0</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Upcoming renewals</div>
        <div class="card-body">
            <div id="dashboard-renewals">No renewals loaded yet.</div>
            <div class="mt-3 d-flex flex-wrap gap-2">
                <a href="/shop/domain-search" class="btn btn-outline-primary btn-sm">Buy domain</a>
                <a href="/shop/cart" class="btn btn-outline-primary btn-sm">Manage cart</a>
            </div>
        </div>
    </div>
</div>

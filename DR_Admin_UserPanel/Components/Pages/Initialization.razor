@page "/initialize"
@layout Layout.PublicLayout

<PageTitle>Initialize - DR Admin Shop</PageTitle>

<div id="shop-initialize-page" class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-7">
            <div class="card shadow-sm">
                <div class="card-header bg-warning-subtle">
                    <h1 class="h5 mb-1"><i class="bi bi-bug"></i> Debug Snapshot Import</h1>
                    <p class="mb-0 small text-muted">Import admin/MyCompany data from API <code>DebugSnapshots</code> JSON file (Debug mode only).</p>
                </div>
                <div class="card-body p-4">
                    <div id="shop-initialize-alert-success" class="alert alert-success d-none" role="alert"></div>
                    <div id="shop-initialize-alert-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="shop-initialize-alert-info" class="alert alert-info" role="alert">
                        Checking API build mode...
                    </div>

                    <form id="shop-initialize-user-form" class="mb-4" novalidate>
                        <h2 class="h6 mb-3"><i class="bi bi-person-plus"></i> Create Shop User</h2>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-username" class="form-label">Username</label>
                                <input id="shop-initialize-username" class="form-control" type="text" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-email" class="form-label">Email</label>
                                <input id="shop-initialize-email" class="form-control" type="email" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-password" class="form-label">Password</label>
                                <input id="shop-initialize-password" class="form-control" type="password" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-confirm-password" class="form-label">Confirm password</label>
                                <input id="shop-initialize-confirm-password" class="form-control" type="password" required />
                            </div>
                            <div class="col-12">
                                <label for="shop-initialize-customer-name" class="form-label">Customer name</label>
                                <input id="shop-initialize-customer-name" class="form-control" type="text" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-contact-first-name" class="form-label">Contact first name</label>
                                <input id="shop-initialize-contact-first-name" class="form-control" type="text" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-contact-last-name" class="form-label">Contact last name</label>
                                <input id="shop-initialize-contact-last-name" class="form-control" type="text" required />
                            </div>
                            <div class="col-12 col-md-6">
                                <label for="shop-initialize-customer-phone" class="form-label">Phone</label>
                                <input id="shop-initialize-customer-phone" class="form-control" type="tel" />
                            </div>
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <button id="shop-initialize-user-button" type="submit" class="btn btn-primary">
                                <i class="bi bi-person-check"></i> Create User
                            </button>
                            <a href="/account/login" class="btn btn-outline-secondary">Go to login</a>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <div id="shop-initialize-import-section" class="d-none">
                        <div class="mb-3">
                            <label for="shop-initialize-file" class="form-label">Snapshot file name</label>
                            <input id="shop-initialize-file" class="form-control" type="text" placeholder="admin-mycompany-debug.json" />
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button id="shop-initialize-import-button" type="button" class="btn btn-warning">
                                <i class="bi bi-upload"></i> Import Snapshot
                            </button>
                            <a href="/account/login" class="btn btn-outline-secondary">Go to login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

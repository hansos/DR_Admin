@page "/shop/domain-search"

<PageTitle>Domain Search</PageTitle>

<div class="container py-4" id="domain-search-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Domain Search</h1>
            <p class="text-muted mb-0">Start your purchase by finding a domain, then bundle hosting and services.</p>
        </div>

<div class="modal fade" id="domain-search-delete-order-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Are you sure you want to delete the current order?</p>
                <p class="mb-0 text-muted small">If the order is already paid, deletion will be blocked.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep order</button>
                <button type="button" class="btn btn-danger" id="domain-search-delete-order-confirm">
                    <i class="bi bi-trash"></i> Delete order
                </button>
            </div>
        </div>
    </div>
</div>
        <button id="domain-search-delete-order-open" type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#domain-search-delete-order-modal">
            <i class="bi bi-trash"></i> Delete order
        </button>
    </div>

<div id="domain-search-basket-panel" class="card shadow border-0 position-fixed d-none" style="left: 1rem; bottom: 1rem; width: min(360px, calc(100vw - 2rem)); z-index: 1030;">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="d-flex align-items-center gap-2">
                <button id="domain-search-basket-drag-handle" type="button" class="btn btn-sm btn-light" aria-label="Move basket" title="Drag to move basket">
                    <i class="bi bi-arrows-move"></i>
                </button>
                <h2 class="h6 mb-0">Basket</h2>
            </div>

<div class="modal fade" id="domain-search-delete-order-modal" tabindex="-1" aria-hidden="true" style="z-index: 2000;">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Are you sure you want to delete the current order?</p>
                <p class="mb-0 text-muted small">If the order is already paid, deletion will be blocked.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep order</button>
                <button type="button" class="btn btn-danger" id="domain-search-delete-order-confirm">
                    <i class="bi bi-trash"></i> Delete order
                </button>
            </div>
        </div>
    </div>
</div>
        </div>
        <div id="domain-search-basket-lines" class="small mb-2"></div>
        <div class="d-flex justify-content-between border-top pt-2 fw-semibold">
            <span>Total</span>
            <span id="domain-search-basket-total">0.00</span>
        </div>
    </div>
</div>

    <div class="card border-0 bg-light-subtle mb-3">
        <div class="card-body py-3">
            <div class="row g-2 small text-muted">
                <div class="col-12 col-md-4"><strong>1.</strong> Search your domain</div>
                <div class="col-12 col-md-4"><strong>2.</strong> Add services and hosting</div>
                <div class="col-12 col-md-4"><strong>3.</strong> Complete checkout</div>
            </div>
        </div>
    </div>

    <div id="domain-search-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="domain-search-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm" id="domain-search-form-card">
        <div class="card-body">
            <form id="domain-search-form" class="row g-3" novalidate>
                <div class="col-12 col-lg-7">
                    <label for="domain-search-input" class="form-label">Domain name</label>
                    <input id="domain-search-input" class="form-control" type="text" placeholder="example.com" required />
                </div>
                <div class="col-12">
                    <button id="domain-search-submit" class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i> Search availability
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mt-3 d-none" id="domain-search-result-card">
        <div class="card-body">
            <h2 class="h6">Result</h2>
            <p id="domain-search-result-summary" class="mb-3"></p>
            <p id="domain-search-result-price" class="mb-3 text-muted d-none"></p>
            <div class="d-flex flex-wrap gap-2 mb-3" id="domain-search-result-actions">
                <button id="domain-search-add-and-bundle" class="btn btn-primary d-none" type="button">
                    <i class="bi bi-bag-check"></i> Add domain & choose hosting/services
                </button>
                <button id="domain-search-transfer" class="btn btn-outline-primary d-none" type="button">
                    <i class="bi bi-arrow-left-right"></i> Initiate transfer
                </button>
                <button id="domain-search-alternatives" class="btn btn-outline-secondary d-none" type="button">
                    <i class="bi bi-lightbulb"></i> Suggest alternatives
                </button>
            </div>
            <div id="domain-search-alternatives-list" class="list-group d-none"></div>
        </div>
    </div>

    <div class="card shadow-sm mt-3 d-none" id="domain-search-upsell-card">
        <div class="card-body">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <div>
                    <h2 class="h6 mb-1">Configure your domain bundle</h2>
                    <p class="text-muted small mb-0">Selected hosting: <span id="domain-search-upsell-hosting-count">0</span> • Selected services: <span id="domain-search-upsell-service-count">0</span></p>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-3">
                    <label for="domain-search-period" class="form-label">Registration period</label>
                    <select id="domain-search-period" class="form-select">
                        <option value="1" selected>1 year</option>
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label for="domain-search-recurring" class="form-label">Payment mode</label>
                    <select id="domain-search-recurring" class="form-select">
                        <option value="one-time" selected>One-time</option>
                        <option value="recurring">Recurring</option>
                    </select>
                </div>
                <div class="col-12 col-md-5 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input id="domain-search-privacy" class="form-check-input" type="checkbox" checked />
                        <label for="domain-search-privacy" class="form-check-label">WHOIS Privacy <span id="domain-search-privacy-price" class="text-muted small">(price unavailable)</span></label>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-xl-6">
                    <h3 class="h6">Hosting packages</h3>
                    <div id="domain-search-upsell-hosting-list" class="list-group"></div>
                </div>
                <div class="col-12 col-xl-6">
                    <h3 class="h6">Optional services</h3>
                    <div id="domain-search-upsell-services-list" class="list-group"></div>
                </div>
            </div>

            <div class="mt-4">
                <button id="domain-search-checkout" type="button" class="btn btn-primary btn-lg w-100">Checkout</button>
            </div>
        </div>
    </div>
</div>

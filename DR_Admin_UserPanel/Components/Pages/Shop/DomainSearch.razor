@page "/shop/domain-search"

<PageTitle>Domain Search</PageTitle>

<div class="container py-4" id="domain-search-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Domain Search</h1>
            <p class="text-muted mb-0">Find an available domain and add it to cart.</p>
        </div>
        <a href="/shop/cart" class="btn btn-outline-primary">Go to cart</a>
    </div>

    <div id="domain-search-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="domain-search-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form id="domain-search-form" class="row g-3" novalidate>
                <div class="col-12 col-lg-5">
                    <label for="domain-search-input" class="form-label">Domain name</label>
                    <input id="domain-search-input" class="form-control" type="text" placeholder="example.com" required />
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <label for="domain-search-registrar" class="form-label">Registrar code</label>
                    <input id="domain-search-registrar" class="form-control" type="text" value="godaddy" required />
                </div>
                <div class="col-12 col-sm-6 col-lg-2">
                    <label for="domain-search-period" class="form-label">Period (years)</label>
                    <select id="domain-search-period" class="form-select">
                        <option value="1" selected>1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                    </select>
                </div>
                <div class="col-12 col-lg-2 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input id="domain-search-privacy" class="form-check-input" type="checkbox" checked />
                        <label for="domain-search-privacy" class="form-check-label">WHOIS Privacy</label>
                    </div>
                </div>
                <div class="col-12">
                    <button id="domain-search-submit" class="btn btn-primary" type="submit">
                        <i class="bi bi-search"></i> Search availability
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mt-3 d-none" id="domain-search-result-card">
        <div class="card-body">
            <h2 class="h6">Result</h2>
            <p id="domain-search-result-summary" class="mb-3"></p>
            <button id="domain-search-add-to-cart" class="btn btn-success d-none" type="button">
                <i class="bi bi-cart-plus"></i> Add to cart
            </button>
        </div>
    </div>
</div>

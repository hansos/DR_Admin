@page "/shop/checkout"

<PageTitle>Checkout</PageTitle>

<div class="container py-4" id="checkout-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Checkout</h1>
            <p class="text-muted mb-0">Confirm order and initialize payment.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button id="checkout-delete-order-open" type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#checkout-delete-order-modal">
                <i class="bi bi-trash"></i> Delete order
            </button>
            <a href="/shop/domain-search?resumeOrder=true" class="btn btn-outline-secondary">Back to order</a>
        </div>
    </div>

    <div id="checkout-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="checkout-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="row g-3">
        <div class="col-12 col-xl-7">
            <div class="card shadow-sm">
                <div class="card-header">Final order summary</div>
                <div class="card-body">
                    <div id="checkout-summary-lines"></div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-5">
            <div class="card shadow-sm mb-3">
                <div class="card-header">Customer confirmation</div>
                <div class="card-body">
                    <form id="checkout-form" novalidate>
                        <div class="mb-3">
                            <div class="border rounded p-3 bg-light-subtle">
                                <div class="d-flex justify-content-between"><span class="text-muted">Customer reference</span><span id="checkout-customer-id-display">-</span></div>
                                <div class="d-flex justify-content-between"><span class="text-muted">Name</span><span id="checkout-customer-name">-</span></div>
                                <div class="d-flex justify-content-between"><span class="text-muted">Email</span><span id="checkout-customer-email">-</span></div>
                            </div>
                            <input id="checkout-customer-id" type="hidden" />
                        </div>
                        <div class="form-check mb-3">
                            <input id="checkout-confirm" class="form-check-input" type="checkbox" required />
                            <label for="checkout-confirm" class="form-check-label">I confirm that the order details are correct.</label>
                        </div>
                        <div class="d-grid">
                            <button id="checkout-submit" class="btn btn-primary" type="submit">
                                <i class="bi bi-credit-card"></i> Place order
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">Payment status</div>
                <div class="card-body" id="checkout-payment-status">Pending initialization.</div>
            </div>

            <div class="card shadow-sm mt-3 d-none" id="checkout-payment-instrument-card">
                <div class="card-header">Choose payment instrument</div>
                <div class="card-body">
                    <div class="mb-2 small text-muted">Order number: <span id="checkout-added-order-number">-</span></div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                            <label for="checkout-payment-instrument" class="form-label mb-0">Payment instrument</label>
                            <button id="checkout-payment-methods-open-create" type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#checkout-payment-methods-modal">
                                <i class="bi bi-plus-circle"></i> Add instrument
                            </button>
                        </div>
                        <select id="checkout-payment-instrument" class="form-select"></select>
                    </div>
                    <div id="checkout-payment-instrument-fields" class="row g-3"></div>
                    <div class="d-grid mt-3">
                        <button id="checkout-payment-instrument-submit" type="button" class="btn btn-outline-primary">Continue to payment</button>
                    </div>

                    <div class="card border mt-3 d-none" id="checkout-stripe-form-card">
                        <div class="card-body">
                            <h3 class="h6 mb-2">Pay with card (Stripe)</h3>
                            <div id="checkout-stripe-card-element" class="mb-2"></div>
                            <div id="checkout-stripe-error" class="text-danger small mb-2 d-none"></div>
                            <button id="checkout-stripe-pay-button" type="button" class="btn btn-primary w-100">Pay now</button>
                        </div>
                    </div>
                </div>

<div class="modal fade" id="checkout-delete-order-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Are you sure you want to delete this order?</p>
                <p class="mb-0 text-muted small">If the order is already paid, deletion will be blocked.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Keep order</button>
                <button type="button" class="btn btn-danger" id="checkout-delete-order-confirm">
                    <i class="bi bi-trash"></i> Delete order
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="checkout-payment-methods-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="checkout-payment-methods-create-form" novalidate>
                <div class="modal-header">
                    <h2 id="checkout-payment-methods-modal-title" class="modal-title fs-5">Add payment instrument</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="checkout-payment-methods-instrument" class="form-label">Payment instrument</label>
                        <select id="checkout-payment-methods-instrument" class="form-select"></select>
                    </div>
                    <div class="form-check">
                        <input id="checkout-payment-methods-default" class="form-check-input" type="checkbox" checked />
                        <label for="checkout-payment-methods-default" class="form-check-label">Set as default</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button id="checkout-payment-methods-create" class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
            </div>
        </div>
    </div>
</div>

@page "/support/tickets"

<PageTitle>Support Tickets</PageTitle>

<div class="container py-4" id="support-tickets-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h4 mb-1">Support Center</h1>
            <p class="text-muted mb-0">Track support requests and create new tickets.</p>
        </div>
        <button id="support-tickets-refresh" class="btn btn-outline-secondary btn-sm" type="button">Refresh</button>
    </div>

    <div id="support-tickets-alert-success" class="alert alert-success d-none" role="alert"></div>
    <div id="support-tickets-alert-error" class="alert alert-danger d-none" role="alert"></div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form id="support-tickets-create-form" class="row g-2" novalidate>
                <div class="col-12 col-md-8">
                    <label for="support-tickets-subject" class="form-label">Subject</label>
                    <input id="support-tickets-subject" class="form-control" type="text" maxlength="150" />
                </div>
                <div class="col-12 col-md-4">
                    <label for="support-tickets-priority" class="form-label">Priority</label>
                    <select id="support-tickets-priority" class="form-select">
                        <option value="Low">Low</option>
                        <option value="Normal" selected>Normal</option>
                        <option value="High">High</option>
                    </select>
                </div>
                <div class="col-12">
                    <label for="support-tickets-message" class="form-label">Message</label>
                    <textarea id="support-tickets-message" class="form-control" rows="2" maxlength="4000"></textarea>
                </div>
                <div class="col-12 col-md-2 d-flex align-items-end">
                    <button id="support-tickets-create" class="btn btn-primary w-100 text-nowrap" type="submit">Create</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Updated</th>
                        </tr>
                    </thead>
                    <tbody id="support-tickets-table-body">
                        <tr><td colspan="5" class="text-center text-muted">Loading tickets...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0" id="support-ticket-details-title">Conversation</h5>
        </div>
        <div class="card-body">
            <div id="support-ticket-thread" class="border rounded p-3 bg-light-subtle" style="min-height: 200px; max-height: 360px; overflow-y: auto;">
                <p class="text-muted mb-0">Select a ticket to see conversation.</p>
            </div>

            <form id="support-ticket-reply-form" class="mt-3" novalidate>
                <label for="support-ticket-reply" class="form-label">Reply</label>
                <textarea id="support-ticket-reply" class="form-control" rows="3" maxlength="4000" disabled></textarea>
                <div class="mt-2 d-flex justify-content-end">
                    <button id="support-ticket-send" class="btn btn-primary" type="submit" disabled>Send</button>
                </div>
            </form>
        </div>
    </div>
</div>
